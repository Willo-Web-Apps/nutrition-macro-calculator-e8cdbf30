<!-- ═══════════════════════════════════════════════════════════════
     CALCULATOR LOGIC — Pure vanilla JS
═══════════════════════════════════════════════════════════════ -->
<script>
  let currentGoal = 'bulk';

  // Goal button toggle
  const goalButtons = document.querySelectorAll('.goal-btn');
  goalButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      currentGoal = btn.dataset.goal;
      goalButtons.forEach(b => {
        if (b.dataset.goal === currentGoal) {
          b.style.background = 'oklch(0.75 0.18 75 / 0.18)';
          b.style.border = '2px solid oklch(0.75 0.18 75)';
          b.style.color = 'oklch(0.82 0.18 78)';
        } else {
          b.style.background = 'oklch(0.13 0.04 152)';
          b.style.border = '2px solid oklch(0.30 0.07 152)';
          b.style.color = 'oklch(0.65 0.05 152)';
        }
      });
    });
  });

  document.getElementById('calculate-btn').addEventListener('click', calculate);

  function calculate() {
    const bf = parseFloat(document.getElementById('body-fat').value);
    const vf = parseFloat(document.getElementById('visceral-fat').value);
    const height = parseFloat(document.getElementById('height').value);
    const sex = document.getElementById('sex').value;

    if (!bf || !vf || !height || bf < 3 || bf > 60 || vf < 1 || vf > 30 || height < 130 || height > 220) {
      alert('Por favor ingresa valores válidos:\n• Grasa corporal: 3–60%\n• Grasa visceral: 1–30\n• Altura: 130–220 cm');
      return;
    }

    // Estimate weight from height (rough midpoint BMI ~22-24)
    // Better: derive from a standard body weight + body fat
    const bmiBase = sex === 'male' ? 23 : 21.5;
    const estimatedWeight = bmiBase * (height / 100) ** 2;
    const leanMass = estimatedWeight * (1 - bf / 100);

    // BMR via Katch-McArdle (lean mass based)
    const bmr = 370 + 21.6 * leanMass;

    // TDEE with moderate activity multiplier (1.55)
    const tdee = bmr * 1.55;

    // High visceral fat penalty
    const highVF = vf >= 9;

    let calories, proteinMultiplier, carbPercent, fatPercent, label, goalNote;

    if (currentGoal === 'bulk') {
      calories = highVF ? tdee + 200 : tdee + 350;
      proteinMultiplier = 2.2;
      carbPercent = highVF ? 0.38 : 0.43;
      fatPercent = 0.25;
      label = '🔺 Volumen';
      goalNote = highVF
        ? 'Tu grasa visceral elevada sugiere un superávit moderado (+200 kcal). Prioriza carbohidratos complejos y evita azúcares simples para optimizar la composición mientras ganas músculo.'
        : 'Superávit controlado de +350 kcal para máxima hipertrofia. Distribuye los carbohidratos alrededor de tus entrenamientos para aprovecharlos al máximo.';
    } else if (currentGoal === 'cut') {
      calories = highVF ? tdee - 500 : tdee - 400;
      proteinMultiplier = 2.6;
      carbPercent = highVF ? 0.28 : 0.35;
      fatPercent = 0.25;
      label = '🔻 Definición';
      goalNote = highVF
        ? 'Déficit de 500 kcal prioritario dado tu nivel de grasa visceral. Aumenta omega-3 (2.5g/día) y magnesio (400mg) para reducir inflamación y mejorar sensibilidad a la insulina.'
        : 'Déficit moderado de 400 kcal preservando masa muscular. La proteína alta (2.6g/kg) es clave para evitar catabolismo muscular durante la fase de definición.';
    } else {
      calories = highVF ? tdee - 150 : tdee;
      proteinMultiplier = 2.0;
      carbPercent = 0.40;
      fatPercent = 0.28;
      label = '⚖️ Mantenimiento';
      goalNote = highVF
        ? 'Con grasa visceral elevada, un pequeño déficit de 150 kcal ayudará a mejorar tu composición sin estrés metabólico. Mantén alta la proteína y monitorea tu evolución mensualmente.'
        : 'Balance neutro para mantener tu composición actual. Ideal para consolidar ganancias o preparar el siguiente ciclo de volumen o definición.';
    }

    const protein = Math.round(leanMass * proteinMultiplier);
    const proteinCal = protein * 4;
    const remainingCal = calories - proteinCal;
    const carbs = Math.round((remainingCal * carbPercent * (1 / (carbPercent + fatPercent))) / 4);
    const fats = Math.round((remainingCal * fatPercent * (1 / (carbPercent + fatPercent))) / 9);
    const totalCal = Math.round(calories);

    const grid = document.getElementById('results-grid');
    grid.innerHTML = `
      <div class="rounded-xl p-4" style="background: oklch(0.13 0.04 152);">
        <p style="color: oklch(0.75 0.18 75); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px;">${label}</p>
        <p class="result-number" style="font-size: 2.8rem; color: oklch(0.82 0.18 78);">${totalCal.toLocaleString('es')}</p>
        <p style="color: oklch(0.55 0.05 152); font-size: 0.75rem; margin-top: 2px;">kcal / día</p>
      </div>
      <div class="rounded-xl p-4" style="background: oklch(0.13 0.04 152);">
        <p style="color: oklch(0.65 0.08 152); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px;">Proteína</p>
        <p class="result-number" style="font-size: 2.8rem; color: oklch(0.95 0.008 80);">${protein}<span style="font-size: 1.2rem; color: oklch(0.55 0.06 152);">g</span></p>
        <p style="color: oklch(0.55 0.05 152); font-size: 0.75rem; margin-top: 2px;">${(protein / leanMass).toFixed(1)}g / kg magro</p>
      </div>
      <div class="rounded-xl p-4" style="background: oklch(0.13 0.04 152);">
        <p style="color: oklch(0.65 0.08 152); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px;">Carbohidratos</p>
        <p class="result-number" style="font-size: 2.8rem; color: oklch(0.95 0.008 80);">${carbs}<span style="font-size: 1.2rem; color: oklch(0.55 0.06 152);">g</span></p>
        <p style="color: oklch(0.55 0.05 152); font-size: 0.75rem; margin-top: 2px;">${Math.round(carbPercent * 100)}% del total</p>
      </div>
      <div class="rounded-xl p-4" style="background: oklch(0.13 0.04 152);">
        <p style="color: oklch(0.65 0.08 152); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px;">Grasas</p>
        <p class="result-number" style="font-size: 2.8rem; color: oklch(0.95 0.008 80);">${fats}<span style="font-size: 1.2rem; color: oklch(0.55 0.06 152);">g</span></p>
        <p style="color: oklch(0.55 0.05 152); font-size: 0.75rem; margin-top: 2px;">${Math.round(fatPercent * 100)}% del total</p>
      </div>
    `;

    document.getElementById('nutrition-note').textContent = goalNote;
    document.getElementById('results-panel').classList.remove('hidden');
    document.getElementById('results-panel').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
</script>
