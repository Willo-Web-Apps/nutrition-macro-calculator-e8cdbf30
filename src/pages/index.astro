---
import Base from '../layouts/Base.astro';
---
<Base
  title="Somatix — Tu composición corporal, convertida en un plan de alimentación"
  description="Ingresa tu grasa corporal, grasa visceral y altura. Obtén tus macros exactos para volumen, definición o mantenimiento en segundos. Gratis, sin descargas."
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO — Full-bleed dark green with calculator widget
  ═══════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden grain-overlay" style="background: oklch(0.13 0.04 152); min-height: 100vh;">

    <!-- Layered gradient lighting -->
    <div class="absolute inset-0 pointer-events-none" style="
      background:
        radial-gradient(ellipse 70% 60% at 15% 20%, oklch(0.36 0.09 152 / 0.55) 0%, transparent 70%),
        radial-gradient(ellipse 50% 45% at 85% 75%, oklch(0.75 0.18 75 / 0.12) 0%, transparent 65%),
        radial-gradient(ellipse 80% 50% at 50% 110%, oklch(0.25 0.08 152 / 0.8) 0%, transparent 60%),
        linear-gradient(168deg, oklch(0.20 0.06 152) 0%, oklch(0.11 0.03 152) 100%);
    "></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 md:pt-28 md:pb-24">

      <!-- Badge -->
      <div class="flex justify-center mb-8 animate-fade-in">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase" style="background: oklch(0.75 0.18 75 / 0.15); border: 1px solid oklch(0.75 0.18 75 / 0.35); color: oklch(0.82 0.18 78);">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><circle cx="5" cy="5" r="5"/></svg>
          Calculadora gratuita · Sin registro
        </span>
      </div>

      <!-- Headline -->
      <div class="text-center max-w-4xl mx-auto mb-4 animate-slide-up delay-100">
        <h1 class="font-display leading-[1.05] tracking-tight" style="font-size: clamp(2.4rem, 6vw, 4.5rem); color: oklch(0.99 0.004 80);">
          Tu composición corporal,<br>
          <span style="color: oklch(0.82 0.18 78);">convertida en un plan</span><br>
          de alimentación
        </h1>
      </div>

      <!-- Sub -->
      <p class="text-center max-w-2xl mx-auto mb-12 animate-slide-up delay-200" style="font-size: 1.125rem; color: oklch(0.78 0.04 152); line-height: 1.65;">
        Ingresa tu grasa corporal, grasa visceral y altura. Obtén tus macros exactos para
        <strong style="color: oklch(0.88 0.01 80); font-weight: 600;">volumen, definición o mantenimiento</strong> — en segundos.
      </p>

      <!-- ─── CALCULATOR CARD ─── -->
      <div class="max-w-4xl mx-auto animate-slide-up delay-300">
        <div class="rounded-2xl p-6 md:p-8 shadow-2xl" style="background: oklch(0.18 0.05 152); border: 1px solid oklch(0.30 0.07 152 / 0.8);">

          <!-- Inputs grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <div>
              <label class="block text-xs font-semibold uppercase tracking-widest mb-2" style="color: oklch(0.65 0.08 152);">Grasa corporal %</label>
              <input
                id="body-fat"
                type="number"
                min="3" max="60" step="0.1"
                placeholder="ej. 18"
                class="calc-input"
              />
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-widest mb-2" style="color: oklch(0.65 0.08 152);">Grasa visceral (1–30)</label>
              <input
                id="visceral-fat"
                type="number"
                min="1" max="30" step="1"
                placeholder="ej. 8"
                class="calc-input"
              />
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-widest mb-2" style="color: oklch(0.65 0.08 152);">Altura (cm)</label>
              <input
                id="height"
                type="number"
                min="130" max="220" step="1"
                placeholder="ej. 175"
                class="calc-input"
              />
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-widest mb-2" style="color: oklch(0.65 0.08 152);">Sexo biológico</label>
              <select id="sex" class="calc-select">
                <option value="male">Masculino</option>
                <option value="female">Femenino</option>
              </select>
            </div>
          </div>

          <!-- Goal selector -->
          <div class="mb-6">
            <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: oklch(0.65 0.08 152);">Objetivo</p>
            <div class="grid grid-cols-3 gap-3" id="goal-buttons">
              <button data-goal="bulk" class="goal-btn goal-active py-3 px-4 rounded-xl font-semibold text-sm transition-all duration-200" style="background: oklch(0.75 0.18 75 / 0.18); border: 2px solid oklch(0.75 0.18 75); color: oklch(0.82 0.18 78);">
                🔺 Volumen
              </button>
              <button data-goal="cut" class="goal-btn py-3 px-4 rounded-xl font-semibold text-sm transition-all duration-200" style="background: oklch(0.13 0.04 152); border: 2px solid oklch(0.30 0.07 152); color: oklch(0.65 0.05 152);">
                🔻 Definición
              </button>
              <button data-goal="maintain" class="goal-btn py-3 px-4 rounded-xl font-semibold text-sm transition-all duration-200" style="background: oklch(0.13 0.04 152); border: 2px solid oklch(0.30 0.07 152); color: oklch(0.65 0.05 152);">
                ⚖️ Mantenimiento
              </button>
            </div>
          </div>

          <!-- Calculate button -->
          <button
            id="calculate-btn"
            class="w-full py-4 rounded-xl font-display text-lg tracking-tight transition-all duration-200 animate-pulse-glow"
            style="background: oklch(0.75 0.18 75); color: oklch(0.13 0.04 152); font-weight: 900;"
            onmouseenter="this.style.background='oklch(0.82 0.18 78)'"
            onmouseleave="this.style.background='oklch(0.75 0.18 75)'"
          >
            Calcular mis macros
          </button>

          <!-- Results panel (hidden until calculated) -->
          <div id="results-panel" class="hidden mt-6 pt-6" style="border-top: 1px solid oklch(0.30 0.07 152);">
            <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: oklch(0.65 0.08 152);">Tu plan personalizado</p>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="results-grid">
              <!-- injected by JS -->
            </div>
            <div class="mt-4 rounded-xl p-4" style="background: oklch(0.75 0.18 75 / 0.08); border: 1px solid oklch(0.75 0.18 75 / 0.25);">
              <p id="nutrition-note" class="text-sm" style="color: oklch(0.82 0.10 90); line-height: 1.6;"></p>
            </div>
          </div>

        </div>
      </div>

      <!-- Trust bar -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-6 animate-fade-in delay-400">
        <div class="flex items-center gap-2 text-sm" style="color: oklch(0.55 0.06 152);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Basado en fórmulas científicas
        </div>
        <div class="flex items-center gap-2 text-sm" style="color: oklch(0.55 0.06 152);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
          100% gratis · Sin registro
        </div>
        <div class="flex items-center gap-2 text-sm" style="color: oklch(0.55 0.06 152);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          Resultados en segundos
        </div>
        <div class="flex items-center gap-2 text-sm" style="color: oklch(0.55 0.06 152);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          Sin descargas
        </div>
      </div>

    </div><!-- /container -->
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       WHY SOMATIX — Problem → Solution split
  ═══════════════════════════════════════════════════════════════ -->
  <section class="relative py-24 md:py-32" style="background: oklch(0.16 0.05 152);">

    <!-- Diagonal top divider -->
    <div class="absolute top-0 left-0 right-0 overflow-hidden leading-none" style="height: 60px;">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-full">
        <polygon points="0,0 1440,0 1440,60" fill="oklch(0.13 0.04 152)"/>
      </svg>
    </div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Left: Problem -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: oklch(0.75 0.18 75);">El problema</p>
          <h2 class="font-display text-3xl md:text-4xl leading-tight mb-6" style="color: oklch(0.99 0.004 80);">
            Tienes los datos de tu báscula. Nadie te dice qué hacer con ellos.
          </h2>
          <div class="space-y-4">
            <div class="flex gap-3">
              <span class="text-2xl mt-0.5">😤</span>
              <p style="color: oklch(0.72 0.04 152); line-height: 1.65;">
                <strong style="color: oklch(0.88 0.01 80);">Las apps genéricas ignoran tu composición corporal.</strong>
                Te dan calorías basadas solo en peso y edad, sin importar si tienes 12% o 28% de grasa.
              </p>
            </div>
            <div class="flex gap-3">
              <span class="text-2xl mt-0.5">💸</span>
              <p style="color: oklch(0.72 0.04 152); line-height: 1.65;">
                <strong style="color: oklch(0.88 0.01 80);">El coaching nutricional cuesta caro.</strong>
                Pagar a un especialista para que interprete tus datos de báscula no debería ser necesario.
              </p>
            </div>
            <div class="flex gap-3">
              <span class="text-2xl mt-0.5">🤷</span>
              <p style="color: oklch(0.72 0.04 152); line-height: 1.65;">
                <strong style="color: oklch(0.88 0.01 80);">La grasa visceral cambia todo.</strong>
                Un nivel alto requiere ajustes específicos que ninguna calculadora estándar contempla.
              </p>
            </div>
          </div>
        </div>

        <!-- Right: Solution -->
        <div class="rounded-2xl p-8" style="background: oklch(0.20 0.06 152); border: 1px solid oklch(0.30 0.07 152);">
          <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: oklch(0.75 0.18 75);">La solución Somatix</p>
          <h3 class="font-display text-2xl md:text-3xl mb-6" style="color: oklch(0.99 0.004 80);">
            Tu báscula ya tiene las respuestas. Nosotros las traducimos.
          </h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="mt-1 flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background: oklch(0.75 0.18 75 / 0.2);">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="oklch(0.82 0.18 78)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <p style="color: oklch(0.78 0.04 152); line-height: 1.6;"><strong style="color: oklch(0.95 0.008 80);">Masa magra real como base.</strong> Calculamos tus macros sobre tu peso libre de grasa, no tu peso total.</p>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background: oklch(0.75 0.18 75 / 0.2);">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="oklch(0.82 0.18 78)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <p style="color: oklch(0.78 0.04 152); line-height: 1.6;"><strong style="color: oklch(0.95 0.008 80);">Ajuste por grasa visceral.</strong> Niveles altos activan recomendaciones de déficit calórico y distribución de macros adaptada.</p>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background: oklch(0.75 0.18 75 / 0.2);">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="oklch(0.82 0.18 78)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <p style="color: oklch(0.78 0.04 152); line-height: 1.6;"><strong style="color: oklch(0.95 0.008 80);">Tres planes en una pantalla.</strong> Volumen, definición y mantenimiento — compara y elige sin salir de la página.</p>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       FEATURE DEEP-DIVES — Alternating left/right
  ═══════════════════════════════════════════════════════════════ -->
  <section class="py-24 md:py-32" style="background: oklch(0.13 0.04 152);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header -->
      <div class="text-center mb-20">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: oklch(0.75 0.18 75);">Cómo funciona</p>
        <h2 class="font-display text-3xl md:text-5xl leading-tight" style="color: oklch(0.99 0.004 80);">
          Ciencia de composición corporal,<br>sin complicaciones
        </h2>
      </div>

      <!-- Feature 1 -->
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-24">
        <!-- Visual -->
        <div class="order-2 lg:order-1 rounded-2xl p-8" style="background: oklch(0.18 0.05 152); border: 1px solid oklch(0.28 0.07 152);">
          <p class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: oklch(0.65 0.08 152);">Resultado de ejemplo · Hombre · 175cm · 20% GC · GV 9</p>
          <div class="grid grid-cols-2 gap-4">
            <div class="rounded-xl p-4" style="background: oklch(0.13 0.04 152);">
              <p class="text-xs uppercase tracking-widest mb-1" style="color: oklch(0.75 0.18 75);">Calorías</p>
              <p class="result-number text-5xl" style="color: oklch(0.82 0.18 78);">2 840</p>
              <p class="text-xs mt-1" style="color: oklch(0.55 0.05 152);">kcal · volumen</p>
            </div>
            <div class="rounded-xl p-4" style="background: oklch(0.13 0.04 152);">
              <p class="text-xs uppercase tracking-widest mb-1" style="color: oklch(0.55 0.06 152);">Proteína</p>
              <p class="result-number text-5xl" style="color: oklch(0.95 0.008 80);">168<span class="text-xl" style="color: oklch(0.55 0.06 152);">g</span></p>
              <p class="text-xs mt-1" style="color: oklch(0.55 0.05 152);">2.4g / kg masa magra</p>
            </div>
            <div class="rounded-xl p-4" style="background: oklch(0.13 0.04 152);">
              <p class="text-xs uppercase tracking-widest mb-1" style="color: oklch(0.55 0.06 152);">Carbohidratos</p>
              <p class="result-number text-5xl" style="color: oklch(0.95 0.008 80);">318<span class="text-xl" style="color: oklch(0.55 0.06 152);">g</span></p>
              <p class="text-xs mt-1" style="color: oklch(0.55 0.05 152);">45% del total</p>
            </div>
            <div class="rounded-xl p-4" style="background: oklch(0.13 0.04 152);">
              <p class="text-xs uppercase tracking-widest mb-1" style="color: oklch(0.55 0.06 152);">Grasas</p>
              <p class="result-number text-5xl" style="color: oklch(0.95 0.008 80);">78<span class="text-xl" style="color: oklch(0.55 0.06 152);">g</span></p>
              <p class="text-xs mt-1" style="color: oklch(0.55 0.05 152);">25% del total</p>
            </div>
          </div>
        </div>
        <!-- Text -->
        <div class="order-1 lg:order-2">
          <span class="inline-block text-4xl font-display mb-4" style="color: oklch(0.75 0.18 75 / 0.4);">01</span>
          <h3 class="font-display text-2xl md:text-3xl mb-4 leading-tight" style="color: oklch(0.99 0.004 80);">
            Macros basados en tu masa magra real
          </h3>
          <p class="mb-4" style="color: oklch(0.72 0.04 152); line-height: 1.7;">
            La mayoría de calculadoras usan tu peso total para distribuir macros. Somatix calcula primero tu masa magra (peso sin grasa) y asigna proteína directamente sobre esa cifra — como lo hacen los preparadores físicos de élite.
          </p>
          <p style="color: oklch(0.72 0.04 152); line-height: 1.7;">
            El resultado: más proteína por kilo que te importa, menos estimaciones vagas.
          </p>
        </div>
      </div>

      <!-- Feature 2 -->
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-24">
        <!-- Text -->
        <div>
          <span class="inline-block text-4xl font-display mb-4" style="color: oklch(0.75 0.18 75 / 0.4);">02</span>
          <h3 class="font-display text-2xl md:text-3xl mb-4 leading-tight" style="color: oklch(0.99 0.004 80);">
            La grasa visceral ajusta tu plan automáticamente
          </h3>
          <p class="mb-4" style="color: oklch(0.72 0.04 152); line-height: 1.7;">
            Un nivel de grasa visceral elevado (9+) es una señal metabólica importante. Somatix detecta tu rango y adapta el déficit calórico, reduce carbohidratos simples recomendados y prioriza micronutrientes antiinflamatorios como omega-3 y magnesio.
          </p>
          <div class="flex gap-3 mt-6">
            <div class="flex-1 rounded-xl p-4 text-center" style="background: oklch(0.18 0.05 152); border: 1px solid oklch(0.28 0.07 152);">
              <p class="text-xs uppercase tracking-widest mb-1" style="color: oklch(0.65 0.08 152);">GV bajo (1–8)</p>
              <p class="font-display text-2xl" style="color: oklch(0.82 0.18 78);">Normal</p>
              <p class="text-xs mt-1" style="color: oklch(0.55 0.06 152);">Plan estándar</p>
            </div>
            <div class="flex-1 rounded-xl p-4 text-center" style="background: oklch(0.18 0.05 152); border: 1px solid oklch(0.65 0.15 30 / 0.5);">
              <p class="text-xs uppercase tracking-widest mb-1" style="color: oklch(0.65 0.15 30);">GV alto (9+)</p>
              <p class="font-display text-2xl" style="color: oklch(0.75 0.18 30);">Ajustado</p>
              <p class="text-xs mt-1" style="color: oklch(0.55 0.06 152);">Déficit prioritario</p>
            </div>
          </div>
        </div>
        <!-- Visual card -->
        <div class="rounded-2xl p-8" style="background: oklch(0.18 0.05 152); border: 1px solid oklch(0.28 0.07 152);">
          <p class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: oklch(0.65 0.08 152);">Nutrientes clave monitoreados</p>
          <div class="space-y-4">
            <div>
              <div class="flex justify-between mb-1">
                <span class="text-sm font-medium" style="color: oklch(0.88 0.01 80);">Proteína completa</span>
                <span class="text-sm font-semibold" style="color: oklch(0.82 0.18 78);">168g</span>
              </div>
              <div class="h-2 rounded-full" style="background: oklch(0.24 0.07 152);">
                <div class="h-2 rounded-full" style="width: 85%; background: linear-gradient(90deg, oklch(0.75 0.18 75), oklch(0.82 0.18 78));"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between mb-1">
                <span class="text-sm font-medium" style="color: oklch(0.88 0.01 80);">Omega-3</span>
                <span class="text-sm font-semibold" style="color: oklch(0.82 0.18 78);">2.5g+</span>
              </div>
              <div class="h-2 rounded-full" style="background: oklch(0.24 0.07 152);">
                <div class="h-2 rounded-full" style="width: 72%; background: linear-gradient(90deg, oklch(0.75 0.18 75), oklch(0.82 0.18 78));"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between mb-1">
                <span class="text-sm font-medium" style="color: oklch(0.88 0.01 80);">Magnesio</span>
                <span class="text-sm font-semibold" style="color: oklch(0.82 0.18 78);">400mg</span>
              </div>
              <div class="h-2 rounded-full" style="background: oklch(0.24 0.07 152);">
                <div class="h-2 rounded-full" style="width: 65%; background: linear-gradient(90deg, oklch(0.75 0.18 75), oklch(0.82 0.18 78));"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between mb-1">
                <span class="text-sm font-medium" style="color: oklch(0.88 0.01 80);">Fibra</span>
                <span class="text-sm font-semibold" style="color: oklch(0.82 0.18 78);">35g</span>
              </div>
              <div class="h-2 rounded-full" style="background: oklch(0.24 0.07 152);">
                <div class="h-2 rounded-full" style="width: 58%; background: linear-gradient(90deg, oklch(0.75 0.18 75), oklch(0.82 0.18 78));"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between mb-1">
                <span class="text-sm font-medium" style="color: oklch(0.88 0.01 80);">Zinc</span>
                <span class="text-sm font-semibold" style="color: oklch(0.82 0.18 78);">15mg</span>
              </div>
              <div class="h-2 rounded-full" style="background: oklch(0.24 0.07 152);">
                <div class="h-2 rounded-full" style="width: 90%; background: linear-gradient(90deg, oklch(0.75 0.18 75), oklch(0.82 0.18 78));"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 3 -->
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Visual -->
        <div class="order-2 lg:order-1">
          <!-- 3 phase cards -->
          <div class="space-y-3">
